# Copy this file to a local shell snippet or export these variables
# before running scripts/nebius-run-all.sh.

# Required: SSH destination for the Nebius VM.
export NEBIUS_USER="ubuntu"
export NEBIUS_HOST="203.0.113.10"

# Optional: SSH key. Omit if your SSH config already handles auth.
# export NEBIUS_SSH_KEY="$HOME/.ssh/id_ed25519"

# Optional: remote project directory.
export NEBIUS_REMOTE_DIR="~/llm-toxic"

# Optional: stable run name used for remote and local evidence folders.
# Defaults to UTC timestamp.
# export NEBIUS_RUN_NAME="h100-full-run-001"

# Optional: remote Python executable used to create the virtualenv.
# export NEBIUS_PYTHON="python3"

# Optional: dependency install mode. Set to 0 if the remote venv already
# has all dependencies installed.
# export NEBIUS_INSTALL_DEPS="1"

# Optional: notebook execution timeout in seconds. -1 disables timeout.
# export NEBIUS_NOTEBOOK_TIMEOUT="-1"

# Optional: extra environment variables for the remote notebook process.
# export HF_TOKEN="..."
# export WANDB_DISABLED="true"
